generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String @id @default(uuid())
  walletAddress String @unique @map("wallet_address")

  // Profile fields (nullable until profile completion)
  name  String?
  email String? @unique
  phone String?

  // Email verification
  emailVerified     Boolean   @default(false) @map("email_verified")
  emailVerifyToken  String?   @map("email_verify_token")
  emailVerifyExpiry DateTime? @map("email_verify_expiry")

  // Referral program
  referralCode    String    @unique @map("referral_code")
  referredBy      String?   @map("referred_by")
  termsAcceptedAt DateTime? @map("terms_accepted_at")

  // Points tracking (cached from blockchain)
  earnedPoints  Int @default(0) @map("earned_points")
  pendingPoints Int @default(0) @map("pending_points")

  // Milestone tracking (cached from blockchain)
  milestoneLevel Int @default(0) @map("milestone_level")

  // Account status
  disabledAt DateTime? @map("disabled_at")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Self-referential relation for referrals
  referrer  User?  @relation("Referrals", fields: [referredBy], references: [id])
  referrals User[] @relation("Referrals")

  // Referral records where this user is the referrer
  sentReferrals    Referral[] @relation("SentReferrals")
  // Referral record where this user is the referee
  receivedReferral Referral?  @relation("ReceivedReferral")

  @@map("users")
}

model Referral {
  id String @id @default(uuid())

  // The user who shared the referral link
  referrerId String @map("referrer_id")
  referrer   User   @relation("SentReferrals", fields: [referrerId], references: [id])

  // The user who signed up via the referral link
  refereeId String @unique @map("referee_id")
  referee   User   @relation("ReceivedReferral", fields: [refereeId], references: [id])

  // Status: pending (signed up) -> completed (on-chain confirmed)
  status Int @default(0)

  //points associated with the action
  points Int 

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("referrals")
}

//Used for the listener service to determine the last block updated_at
model ChainSyncState {
  id                    Int    @id @default(1)
  lastProcessedBlock    BigInt
  lastProcessedLogIndex Int
}

// Milestone tier definitions
model MilestoneTier {
  level          Int    @id // 0-indexed milestone level
  name           String // e.g. "Bronze", "Silver"
  pointsRequired Int    @map("points_required")
  benefits       String[] // list of benefit descriptions

  @@map("milestone_tiers")
}

//Keeps track of the users invites
model Invite {
  inviteId String @id @db.VarChar(66) // bytes32 hex string
  referrer String @db.VarChar(42) // wallet address
  status   Int // enum value from solidity
  points   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrer])
}
